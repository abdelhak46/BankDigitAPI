# ─── PostgreSQL ───────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=bankdigit
DB_USER=postgres
DB_PASSWORD=your_password

# ─── JWT ──────────────────────────────────────────────────────
JWT_ACCESS_SECRET=change_me_access_super_secret_key_256bits
JWT_REFRESH_SECRET=change_me_refresh_super_secret_key_256bits
JWT_TEMP_SECRET=change_me_temp_otp_secret_key_256bits
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d
JWT_TEMP_EXPIRES=10m

# ─── Nodemailer (SMTP) ────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM="BankDigit <noreply@bankdigit.dz>"

# ─── App ──────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
